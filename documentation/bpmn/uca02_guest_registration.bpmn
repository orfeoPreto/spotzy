<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uca02_guest_registration" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uca02_guest_registration" name="UC-A02 — Guest Registration" isExecutable="false">
    <startEvent id="start" name="Arrive at /auth/register" />
    <userTask id="select_guest" name="Select Guest persona" />
    <userTask id="profile_form" name="Fill profile form" />
    <userTask id="otp" name="Verify email (OTP)" />
    <serviceTask id="create_account" name="Create Guest account&#10;stripeConnectEnabled=false" />
    <serviceTask id="redirect" name="Navigate to /search" />
    <endEvent id="end" name="Guest registered" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="select_guest" />
    <sequenceFlow id="f2" sourceRef="select_guest" targetRef="profile_form" />
    <sequenceFlow id="f3" sourceRef="profile_form" targetRef="otp" />
    <sequenceFlow id="f4" sourceRef="otp" targetRef="create_account" />
    <sequenceFlow id="f5" sourceRef="create_account" targetRef="redirect" />
    <sequenceFlow id="f6" sourceRef="redirect" targetRef="end" />
  </process>

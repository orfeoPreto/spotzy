<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uch11_dispute" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uch11_dispute" name="UC-H11 — Open and Resolve a Dispute" isExecutable="false">
    <startEvent id="start" name="User opens dispute&#10;from booking card" />
    <serviceTask id="open_dispute" name="Create dispute record&#10;(POST /disputes)" />
    <userTask id="ai_triage" name="AI triage chat&#10;(Spotzy Support messages)" />
    <exclusiveGateway id="gw_resolve" name="AI resolution&#10;successful?" />
    <serviceTask id="auto_resolve" name="Apply automatic resolution&#10;(refund or no refund)" />
    <serviceTask id="escalate" name="Escalate to human agent&#10;(emit dispute.escalated event)" />
    <userTask id="agent_review" name="Agent reviews&#10;evidence and messages" />
    <serviceTask id="agent_decision" name="Agent applies decision&#10;(Stripe refund if applicable)" />
    <serviceTask id="notify_parties" name="Notify both parties&#10;of outcome" />
    <endEvent id="end" name="Dispute resolved" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="open_dispute" />
    <sequenceFlow id="f2" sourceRef="open_dispute" targetRef="ai_triage" />
    <sequenceFlow id="f3" sourceRef="ai_triage" targetRef="gw_resolve" />
    <sequenceFlow id="f4" name="Yes" sourceRef="gw_resolve" targetRef="auto_resolve" />
    <sequenceFlow id="f5" name="No" sourceRef="gw_resolve" targetRef="escalate" />
    <sequenceFlow id="f6" sourceRef="auto_resolve" targetRef="notify_parties" />
    <sequenceFlow id="f7" sourceRef="escalate" targetRef="agent_review" />
    <sequenceFlow id="f8" sourceRef="agent_review" targetRef="agent_decision" />
    <sequenceFlow id="f9" sourceRef="agent_decision" targetRef="notify_parties" />
    <sequenceFlow id="f10" sourceRef="notify_parties" targetRef="end" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_uch11_dispute">
    <bpmndi:BPMNPlane id="Plane_uch11_dispute" bpmnElement="uch11_dispute">
      <bpmndi:BPMNShape id="shape_open_dispute" bpmnElement="open_dispute">
        <dc:Bounds x="246" y="110" width="120" height="60" />

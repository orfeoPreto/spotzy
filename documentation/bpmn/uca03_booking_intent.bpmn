<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uca03_booking_intent" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uca03_booking_intent" name="UC-A03 — Booking Intent Preservation" isExecutable="false">
    <startEvent id="start" name="Tap &#34;Book this spot&#34;&#10;(unauthenticated)" />
    <scriptTask id="capture_intent" name="Capture booking intent&#10;(listingId, dates, listing data)" />
    <scriptTask id="store_intent" name="Store in sessionStorage&#10;+ encode URL params" />
    <serviceTask id="redirect_login" name="Redirect to /auth/login&#10;+ show booking summary strip" />
    <exclusiveGateway id="gw_user_type" name="User type?" />
    <userTask id="login" name="Log in (existing user)" />
    <callActivity id="register" name="Register (new user)&#10;UC-A01 or UC-A02" />
    <scriptTask id="read_intent" name="Read intent from&#10;sessionStorage / URL params" />
    <exclusiveGateway id="gw_intent_found" name="Intent found?" />
    <serviceTask id="navigate_checkout" name="Navigate to /checkout&#10;with listingId + dates" />
    <serviceTask id="navigate_search" name="Navigate to /search&#10;+ show expired toast" />
    <scriptTask id="clear_intent" name="Clear sessionStorage intent" />
    <userTask id="checkout" name="Render checkout page&#10;(data from intent cache)" />
    <endEvent id="end_success" name="Guest on checkout&#10;with booking data" />
    <endEvent id="end_expired" name="Guest on search&#10;(intent expired)" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="capture_intent" />
    <sequenceFlow id="f2" sourceRef="capture_intent" targetRef="store_intent" />
    <sequenceFlow id="f3" sourceRef="store_intent" targetRef="redirect_login" />
    <sequenceFlow id="f4" sourceRef="redirect_login" targetRef="gw_user_type" />
    <sequenceFlow id="f5" name="Existing user" sourceRef="gw_user_type" targetRef="login" />
    <sequenceFlow id="f6" name="New user" sourceRef="gw_user_type" targetRef="register" />
    <sequenceFlow id="f7" sourceRef="login" targetRef="read_intent" />
    <sequenceFlow id="f8" sourceRef="register" targetRef="read_intent" />
    <sequenceFlow id="f9" sourceRef="read_intent" targetRef="gw_intent_found" />
    <sequenceFlow id="f10" name="Yes" sourceRef="gw_intent_found" targetRef="navigate_checkout" />
    <sequenceFlow id="f11" name="No — expired" sourceRef="gw_intent_found" targetRef="navigate_search" />
    <sequenceFlow id="f12" sourceRef="navigate_checkout" targetRef="clear_intent" />
    <sequenceFlow id="f13" sourceRef="clear_intent" targetRef="checkout" />
    <sequenceFlow id="f14" sourceRef="checkout" targetRef="end_success" />
    <sequenceFlow id="f15" sourceRef="navigate_search" targetRef="end_expired" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_uca03_booking_intent">

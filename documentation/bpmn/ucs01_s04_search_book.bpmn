<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ucs01_s04_search_book" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="ucs01_s04_search_book" name="UC-S01/S04 — Search and Book a Parking Spot" isExecutable="false">
    <startEvent id="start" name="Open search screen">
      <outgoing>Flow_10dnpkm</outgoing>
    </startEvent>
    <scriptTask id="map_load" name="Map loads&#10;(Brussels default centre)">
      <incoming>Flow_10dnpkm</incoming>
    </scriptTask>
    <userTask id="search" name="Enter destination&#10;(Mapbox autocomplete)" />
    <userTask id="filter" name="Apply filters&#10;(optional)" />
    <userTask id="view_results" name="View results&#10;(map pins + list panel)">
      <incoming>f4</incoming>
    </userTask>
    <userTask id="select_spot" name="Select a listing" />
    <userTask id="view_listing" name="View listing detail page" />
    <userTask id="select_dates" name="Select dates and times" />
    <exclusiveGateway id="gw_auth" name="User authenticated?" />
    <callActivity id="intent_capture" name="Capture booking intent&#10;→ redirect to login&#10;(UC-A03)" />
    <exclusiveGateway id="gw_own" name="Own listing?" />
    <scriptTask id="show_own" name="Show &#34;This is your listing&#34;&#10;(BR-SB01)" />
    <userTask id="review_booking" name="Step 1: Review booking&#10;+ price breakdown" />
    <serviceTask id="hard_validate" name="Hard availability re-validation&#10;(ConsistentRead DynamoDB)" />
    <exclusiveGateway id="gw_avail" name="Still available?" />
    <userTask id="payment" name="Step 2: Enter payment&#10;(Stripe Elements)" />
    <serviceTask id="create_booking" name="Create booking&#10;+ Stripe PaymentIntent" />
    <userTask id="confirmation" name="Step 3: Confirmation screen&#10;+ booking reference" />
    <endEvent id="end_booked" name="Booking confirmed" />
    <endEvent id="end_unavail" name="Spot unavailable&#10;— return to search" />
    <endEvent id="end_own" name="Own listing&#10;— no booking" />
    <sequenceFlow id="f2" sourceRef="map_load" targetRef="search" />
    <sequenceFlow id="f3" sourceRef="search" targetRef="filter" />
    <sequenceFlow id="f4" sourceRef="filter" targetRef="view_results" />
    <sequenceFlow id="f6" sourceRef="view_results" targetRef="select_spot" />
    <sequenceFlow id="f7" sourceRef="select_spot" targetRef="view_listing" />
    <sequenceFlow id="f8" sourceRef="view_listing" targetRef="select_dates" />
    <sequenceFlow id="f9" sourceRef="select_dates" targetRef="gw_auth" />
    <sequenceFlow id="f10" name="No" sourceRef="gw_auth" targetRef="intent_capture" />
    <sequenceFlow id="f11" name="Yes" sourceRef="gw_auth" targetRef="gw_own" />
    <sequenceFlow id="f12" name="Yes" sourceRef="gw_own" targetRef="show_own" />
    <sequenceFlow id="f13" name="No" sourceRef="gw_own" targetRef="review_booking" />
    <sequenceFlow id="f14" sourceRef="review_booking" targetRef="hard_validate" />
    <sequenceFlow id="f15" sourceRef="hard_validate" targetRef="gw_avail" />
    <sequenceFlow id="f16" name="Yes" sourceRef="gw_avail" targetRef="payment" />
    <sequenceFlow id="f17" name="No" sourceRef="gw_avail" targetRef="end_unavail" />
    <sequenceFlow id="f18" sourceRef="payment" targetRef="create_booking" />
    <sequenceFlow id="f19" sourceRef="create_booking" targetRef="confirmation" />
    <sequenceFlow id="f20" sourceRef="confirmation" targetRef="end_booked" />
    <sequenceFlow id="f21" sourceRef="show_own" targetRef="end_own" />
    <sequenceFlow id="Flow_10dnpkm" sourceRef="start" targetRef="map_load" />
  </process>

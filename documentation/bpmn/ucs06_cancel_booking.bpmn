<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ucs06_cancel" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="ucs06_cancel" name="UC-S06 — Cancel a Booking" isExecutable="false">
    <startEvent id="start" name="Guest taps&#10;&#34;Cancel booking&#34;" />
    <userTask id="show_modal" name="Show cancel modal&#10;(refund amount, policy)" />
    <exclusiveGateway id="gw_confirm" name="User confirms&#10;cancellation?" />
    <serviceTask id="call_api" name="POST /bookings/{id}/cancel&#10;(with Authorization header)" />
    <serviceTask id="stripe_refund" name="Process Stripe refund&#10;(per cancellation policy)" />
    <serviceTask id="emit_event" name="Emit booking.cancelled&#10;(EventBridge)" />
    <serviceTask id="notify" name="Notify Host&#10;(SMS + email)" />
    <serviceTask id="release_avail" name="Release availability blocks&#10;(availability-release Lambda)" />
    <endEvent id="end_cancelled" name="Booking cancelled&#10;Refund issued">
      <incoming>f9</incoming>
    </endEvent>
    <endEvent id="end_kept" name="Booking kept">
      <incoming>f4</incoming>
    </endEvent>
    <sequenceFlow id="f1" sourceRef="start" targetRef="show_modal" />
    <sequenceFlow id="f2" sourceRef="show_modal" targetRef="gw_confirm" />
    <sequenceFlow id="f3" name="Yes — cancel" sourceRef="gw_confirm" targetRef="call_api" />
    <sequenceFlow id="f4" name="No — keep" sourceRef="gw_confirm" targetRef="end_kept" />
    <sequenceFlow id="f5" sourceRef="call_api" targetRef="stripe_refund" />
    <sequenceFlow id="f6" sourceRef="stripe_refund" targetRef="emit_event" />
    <sequenceFlow id="f7" sourceRef="emit_event" targetRef="notify" />
    <sequenceFlow id="f8" sourceRef="notify" targetRef="release_avail" />
    <sequenceFlow id="f9" sourceRef="release_avail" targetRef="end_cancelled" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_ucs06_cancel">
    <bpmndi:BPMNPlane id="Plane_ucs06_cancel" bpmnElement="ucs06_cancel">

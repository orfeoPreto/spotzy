<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uch10_rating" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uch10_rating" name="UC-H10/S07 — Rating Flow" isExecutable="false">
    <startEvent id="start" name="Booking status&#10;becomes COMPLETED">
      <outgoing>Flow_0l2kc1i</outgoing>
    </startEvent>
    <serviceTask id="prompt_host" name="Prompt Host to rate Guest&#10;(notification)" />
    <serviceTask id="prompt_guest" name="Prompt Guest to rate&#10;Host and Spot (notification)" />
    <userTask id="host_rates" name="Host submits rating&#10;(3 sections, 1–5 stars)" />
    <userTask id="guest_rates" name="Guest submits rating&#10;(4 sections, 1–5 stars)" />
    <exclusiveGateway id="gw_both" name="Both parties rated&#10;or 7-day window passed?" />
    <serviceTask id="publish_reviews" name="Publish reviews&#10;(both become visible)" />
    <serviceTask id="update_averages" name="Update average ratings&#10;for Host and Guest" />
    <endEvent id="end" name="Reviews published&#10;and visible on&#10;presentation pages" />
    <sequenceFlow id="f1" sourceRef="Gateway_1yetknt" targetRef="prompt_host" />
    <sequenceFlow id="f2" sourceRef="Gateway_1yetknt" targetRef="prompt_guest" />
    <sequenceFlow id="f3" sourceRef="prompt_host" targetRef="host_rates" />
    <sequenceFlow id="f4" sourceRef="prompt_guest" targetRef="guest_rates" />
    <sequenceFlow id="f5" sourceRef="host_rates" targetRef="gw_both" />
    <sequenceFlow id="f6" sourceRef="guest_rates" targetRef="gw_both" />
    <sequenceFlow id="f7" name="Yes" sourceRef="gw_both" targetRef="publish_reviews" />
    <sequenceFlow id="f8" sourceRef="publish_reviews" targetRef="update_averages" />
    <sequenceFlow id="f9" sourceRef="update_averages" targetRef="end" />
    <sequenceFlow id="Flow_0l2kc1i" sourceRef="start" targetRef="Gateway_1yetknt" />
    <parallelGateway id="Gateway_1yetknt">
      <incoming>Flow_0l2kc1i</incoming>
      <outgoing>f2</outgoing>
      <outgoing>f1</outgoing>
    </parallelGateway>
  </process>

<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uch01_h04_listing" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uch01_h04_listing" name="UC-H01/H04 — Create and Publish Listing" isExecutable="false">
    <startEvent id="start" name="Host clicks&#10;&#34;Add a spot&#34;" />
    <userTask id="location" name="Step 1: Enter location&#10;(Mapbox autocomplete)" />
    <userTask id="details" name="Step 2: Spot details&#10;(type, size, EV, description)" />
    <userTask id="photos" name="Step 3: Upload photos&#10;(min 1, max 5)" />
    <serviceTask id="ai_validate" name="AI photo validation&#10;(Rekognition)" />
    <exclusiveGateway id="gw_photos" name="Photos valid?" />
    <userTask id="availability" name="Step 4: Availability&#10;(ALWAYS or WEEKLY)" />
    <userTask id="pricing" name="Step 4: Set pricing&#10;(hourly / daily / monthly)" />
    <serviceTask id="save_draft" name="Save as DRAFT" />
    <userTask id="checklist" name="View publish checklist" />
    <exclusiveGateway id="gw_complete" name="All checks pass?" />
    <serviceTask id="publish" name="Publish listing" />
    <serviceTask id="set_live" name="Set status = LIVE&#10;Emit listing.published event" />
    <endEvent id="end_live" name="Listing is LIVE" />
    <endEvent id="end_draft" name="Listing saved as DRAFT" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="location" />
    <sequenceFlow id="f2" sourceRef="location" targetRef="details" />
    <sequenceFlow id="f3" sourceRef="details" targetRef="photos" />
    <sequenceFlow id="f4" sourceRef="photos" targetRef="ai_validate" />
    <sequenceFlow id="f5" sourceRef="ai_validate" targetRef="gw_photos" />
    <sequenceFlow id="f6" name="Pass" sourceRef="gw_photos" targetRef="availability" />
    <sequenceFlow id="f6b" name="Fail — re-upload" sourceRef="gw_photos" targetRef="photos" />
    <sequenceFlow id="f7" sourceRef="availability" targetRef="pricing" />
    <sequenceFlow id="f8" sourceRef="pricing" targetRef="save_draft" />
    <sequenceFlow id="f9" sourceRef="save_draft" targetRef="checklist" />
    <sequenceFlow id="f10" sourceRef="checklist" targetRef="gw_complete" />
    <sequenceFlow id="f11" name="Yes" sourceRef="gw_complete" targetRef="publish" />
    <sequenceFlow id="f11b" name="No — fix issues" sourceRef="gw_complete" targetRef="save_draft" />
    <sequenceFlow id="f12" sourceRef="publish" targetRef="set_live" />
    <sequenceFlow id="f13" sourceRef="set_live" targetRef="end_live" />
    <sequenceFlow id="f14" name="Save as draft" sourceRef="save_draft" targetRef="end_draft" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_uch01_h04_listing">

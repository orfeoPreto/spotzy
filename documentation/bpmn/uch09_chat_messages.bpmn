<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uch09_chat" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uch09_chat" name="UC-H09/S — Chat and Messages Flow" isExecutable="false">
    <startEvent id="start" name="User opens&#10;Messages section&#10;or booking card" />
    <exclusiveGateway id="gw_entry" name="Entry point?" />
    <userTask id="messages_list" name="View conversation list&#10;(/messages)" />
    <userTask id="direct_thread" name="Open specific chat thread&#10;(bypasses list)" />
    <userTask id="select_convo" name="Select conversation" />
    <userTask id="open_thread" name="Open chat thread&#10;(booking context banner)" />
    <userTask id="send_message" name="Send message&#10;(text or image)" />
    <serviceTask id="ws_deliver" name="Deliver via WebSocket&#10;to recipient" />
    <serviceTask id="increment_unread" name="Increment unread count&#10;(UNREAD#{bookingId})" />
    <serviceTask id="update_badge" name="Update nav unread badge&#10;(real-time)" />
    <exclusiveGateway id="gw_more" name="Continue chatting?" />
    <endEvent id="end" name="Chat session ended" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="gw_entry" />
    <sequenceFlow id="f2" name="Via Messages tab" sourceRef="gw_entry" targetRef="messages_list" />
    <sequenceFlow id="f3" name="Via booking card" sourceRef="gw_entry" targetRef="direct_thread" />
    <sequenceFlow id="f4" sourceRef="messages_list" targetRef="select_convo" />
    <sequenceFlow id="f5" sourceRef="select_convo" targetRef="open_thread" />
    <sequenceFlow id="f6" sourceRef="direct_thread" targetRef="open_thread" />
    <sequenceFlow id="f7" sourceRef="open_thread" targetRef="send_message" />
    <sequenceFlow id="f8" sourceRef="send_message" targetRef="ws_deliver" />
    <sequenceFlow id="f9" sourceRef="ws_deliver" targetRef="increment_unread" />
    <sequenceFlow id="f10" sourceRef="increment_unread" targetRef="update_badge" />
    <sequenceFlow id="f11" sourceRef="update_badge" targetRef="gw_more" />
    <sequenceFlow id="f12" name="Yes" sourceRef="gw_more" targetRef="send_message" />
    <sequenceFlow id="f13" name="No" sourceRef="gw_more" targetRef="end" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_uch09_chat">
    <bpmndi:BPMNPlane id="Plane_uch09_chat" bpmnElement="uch09_chat">

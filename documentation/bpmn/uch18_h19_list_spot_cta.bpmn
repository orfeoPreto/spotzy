<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uch18_h19_list_spot" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uch18_h19_list_spot" name="UC-H18/H19 — List Your Spot CTA Flow" isExecutable="false">
    <startEvent id="start" name="User clicks&#10;&#34;List your spot&#34;" />
    <exclusiveGateway id="gw_auth" name="Authenticated?" />
    <callActivity id="register_flow" name="UC-A01 — Host registration&#10;(Stripe Connect included)" />
    <exclusiveGateway id="gw_host" name="Has Host persona?&#10;(stripeConnectEnabled=true)" />
    <serviceTask id="direct_listing" name="Navigate directly&#10;to /listings/new" />
    <userTask id="become_host" name="Show Become a Host&#10;interstitial screen" />
    <userTask id="stripe_connect" name="Complete Stripe Connect&#10;onboarding" />
    <exclusiveGateway id="gw_stripe" name="Stripe completed?" />
    <serviceTask id="activate_host" name="Set stripeConnectEnabled=true&#10;Activate Host badge" />
    <serviceTask id="listing_new" name="Navigate to /listings/new" />
    <serviceTask id="back_interstitial" name="Return to interstitial&#10;(not abandoned)" />
    <endEvent id="end_listing" name="Host on&#10;/listings/new" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="gw_auth" />
    <sequenceFlow id="f2" name="No — unauthenticated" sourceRef="gw_auth" targetRef="register_flow" />
    <sequenceFlow id="f3" name="Yes — authenticated" sourceRef="gw_auth" targetRef="gw_host" />
    <sequenceFlow id="f4" name="Yes" sourceRef="gw_host" targetRef="direct_listing" />
    <sequenceFlow id="f5" name="No — Guest only" sourceRef="gw_host" targetRef="become_host" />
    <sequenceFlow id="f6" sourceRef="become_host" targetRef="stripe_connect" />
    <sequenceFlow id="f7" sourceRef="stripe_connect" targetRef="gw_stripe" />
    <sequenceFlow id="f8" name="Completed" sourceRef="gw_stripe" targetRef="activate_host" />
    <sequenceFlow id="f9" name="Abandoned" sourceRef="gw_stripe" targetRef="back_interstitial" />
    <sequenceFlow id="f10" sourceRef="back_interstitial" targetRef="become_host" />
    <sequenceFlow id="f11" sourceRef="activate_host" targetRef="listing_new" />
    <sequenceFlow id="f12" sourceRef="direct_listing" targetRef="end_listing" />
    <sequenceFlow id="f13" sourceRef="listing_new" targetRef="end_listing" />
    <sequenceFlow id="f14" sourceRef="register_flow" targetRef="end_listing" />
  </process>

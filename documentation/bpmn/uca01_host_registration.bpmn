<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_uca01_host_registration" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="uca01_host_registration" name="UC-A01 — Host Registration" isExecutable="false">
    <laneSet id="ls_uca01_host_registration">
      <lane id="lane_system" name="System">
        <flowNodeRef>gen_stripe_url</flowNodeRef>
        <flowNodeRef>create_account_host</flowNodeRef>
        <flowNodeRef>create_account_guest</flowNodeRef>
        <flowNodeRef>redirect_listings</flowNodeRef>
        <flowNodeRef>redirect_dashboard</flowNodeRef>
      </lane>
      <lane id="lane_visitor" name="Visitor">
        <flowNodeRef>select_host</flowNodeRef>
        <flowNodeRef>stripe_gate</flowNodeRef>
        <flowNodeRef>stripe_connect</flowNodeRef>
        <flowNodeRef>profile_form</flowNodeRef>
        <flowNodeRef>otp</flowNodeRef>
        <flowNodeRef>Gateway_1i2l112</flowNodeRef>
        <flowNodeRef>start</flowNodeRef>
        <flowNodeRef>check_stripe</flowNodeRef>
        <flowNodeRef>end_host</flowNodeRef>
        <flowNodeRef>end_guest</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start" name="Arrive at /auth/register" />
    <userTask id="select_host" name="Select Host persona" />
    <serviceTask id="gen_stripe_url" name="Generate Stripe Connect URL" />
    <userTask id="stripe_gate" name="View Stripe gate screen" />
    <userTask id="stripe_connect" name="Complete Stripe Connect onboarding" />
    <exclusiveGateway id="check_stripe" name="Stripe completed?" />
    <userTask id="profile_form" name="Fill profile form" />
    <userTask id="otp" name="Verify email (OTP)">
      <outgoing>Flow_068scna</outgoing>
    </userTask>
    <serviceTask id="create_account_host" name="Create account&#10;Host+Guest personas&#10;stripeConnectEnabled=true" />
    <serviceTask id="create_account_guest" name="Create account&#10;Guest only&#10;stripeConnectEnabled=false" />
    <serviceTask id="redirect_listings" name="Navigate to /listings/new" />
    <serviceTask id="redirect_dashboard" name="Navigate to /dashboard/guest&#10;+ incomplete payout banner" />
    <endEvent id="end_host" name="Host registered" />
    <endEvent id="end_guest" name="Guest registered&#10;(payout pending)" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="select_host" />
    <sequenceFlow id="f2" sourceRef="select_host" targetRef="gen_stripe_url" />
    <sequenceFlow id="f3" sourceRef="gen_stripe_url" targetRef="stripe_gate" />
    <sequenceFlow id="f4" sourceRef="stripe_gate" targetRef="stripe_connect" />
    <sequenceFlow id="f5" sourceRef="stripe_connect" targetRef="check_stripe" />
    <sequenceFlow id="f6" name="Yes — completed" sourceRef="check_stripe" targetRef="profile_form" />
    <sequenceFlow id="f6b" name="No — abandoned" sourceRef="check_stripe" targetRef="profile_form" />
    <sequenceFlow id="f7" sourceRef="profile_form" targetRef="otp" />
    <sequenceFlow id="f8a" name="Stripe success" sourceRef="Gateway_1i2l112" targetRef="create_account_host" />
    <sequenceFlow id="f8b" name="Stripe abandoned" sourceRef="Gateway_1i2l112" targetRef="create_account_guest" />
    <sequenceFlow id="f9a" sourceRef="create_account_host" targetRef="redirect_listings" />
    <sequenceFlow id="f9b" sourceRef="create_account_guest" targetRef="redirect_dashboard" />
    <sequenceFlow id="f10a" sourceRef="redirect_listings" targetRef="end_host" />
    <sequenceFlow id="f10b" sourceRef="redirect_dashboard" targetRef="end_guest" />
    <exclusiveGateway id="Gateway_1i2l112">
      <incoming>Flow_068scna</incoming>
      <outgoing>f8a</outgoing>
      <outgoing>f8b</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_068scna" sourceRef="otp" targetRef="Gateway_1i2l112" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_uca01_host_registration">
    <bpmndi:BPMNPlane id="Plane_uca01_host_registration" bpmnElement="uca01_host_registration">

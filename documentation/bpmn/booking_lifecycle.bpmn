<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_booking_lifecycle" targetNamespace="http://spotzy.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <process id="booking_lifecycle" name="Booking Lifecycle — Status Transitions" isExecutable="false">
    <startEvent id="start" name="Booking created" />
    <task id="pending" name="PENDING&#10;(payment authorised)" />
    <exclusiveGateway id="gw_payment" name="Payment confirmed?" />
    <task id="confirmed" name="CONFIRMED&#10;(booking secured)" />
    <exclusiveGateway id="gw_start" name="Booking start time&#10;reached?" />
    <task id="active" name="ACTIVE&#10;(in progress)" />
    <exclusiveGateway id="gw_end" name="Booking end time&#10;reached?" />
    <task id="completed" name="COMPLETED&#10;(payout triggered)" />
    <exclusiveGateway id="gw_cancel" name="Cancellation&#10;requested?" />
    <task id="cancelled" name="CANCELLED&#10;(refund per policy)" />
    <exclusiveGateway id="gw_dispute" name="Dispute opened?" />
    <task id="disputed" name="DISPUTED&#10;(payout on hold)" />
    <endEvent id="end_complete" name="Booking complete&#10;Review prompts sent" />
    <endEvent id="end_cancel" name="Booking cancelled" />
    <endEvent id="end_dispute" name="Dispute resolved" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="pending" />
    <sequenceFlow id="f2" sourceRef="pending" targetRef="gw_payment" />
    <sequenceFlow id="f3" name="Succeeded" sourceRef="gw_payment" targetRef="confirmed" />
    <sequenceFlow id="f4" name="Failed" sourceRef="gw_payment" targetRef="cancelled" />
    <sequenceFlow id="f5" sourceRef="confirmed" targetRef="gw_cancel" />
    <sequenceFlow id="f6" name="Yes — before start" sourceRef="gw_cancel" targetRef="cancelled" />
    <sequenceFlow id="f7" name="No" sourceRef="gw_cancel" targetRef="gw_start" />
    <sequenceFlow id="f8" name="Yes" sourceRef="gw_start" targetRef="active" />
    <sequenceFlow id="f9" sourceRef="active" targetRef="gw_end" />
    <sequenceFlow id="f10" name="Yes" sourceRef="gw_end" targetRef="completed" />
    <sequenceFlow id="f11" sourceRef="completed" targetRef="gw_dispute" />
    <sequenceFlow id="f12" name="Yes" sourceRef="gw_dispute" targetRef="disputed" />
    <sequenceFlow id="f13" name="No" sourceRef="gw_dispute" targetRef="end_complete" />
    <sequenceFlow id="f14" sourceRef="cancelled" targetRef="end_cancel" />
    <sequenceFlow id="f15" sourceRef="disputed" targetRef="end_dispute" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_booking_lifecycle">

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": ["functions/**/*.ts", "shared/**/*.ts", "__tests__/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
